twork\\front-react\\src\\components\\Navbar\\Navbar.js",[],"C:\\Users\\jnam0\\Documents\\GitHub\\agSocialNetwork\\front-react\\src\\components\\Pages\\Forums.js",[],"C:\\Users\\jnam0\\Documents\\GitHub\\agSocialNetwork\\front-react\\src\\components\\Pages\\SignUp.js",["55","56","57"],"import React, { useState, useRef, useEffect } from 'react';\r\nimport Users from './Users'\r\nimport {BrowserRouter as Router, Switch, Route} from 'react-router-dom';\r\n\r\nimport '../../App.css';\r\nimport '../Button/Button.css';\r\n\r\nconst LOCAL_STORAGE = 'userList'\r\n\r\nexport default function SignUp() {\r\n  const [users, setUsername] = useState([])\r\n  const userNameRef = useRef()\r\n  const passwordRef = useRef()\r\n  const firstNameRef = useRef()\r\n  const lastNameRef = useRef()\r\n\r\n  useEffect(() => {\r\n    localStorage.setItem(LOCAL_STORAGE, JSON.stringify(users))\r\n  }, [users])\r\n\r\n  function handleFormSubmit(e) {\r\n    const name = userNameRef.current.value\r\n    const password = passwordRef.current.value\r\n    \r\n    if (name === '') return //handle error\r\n    console.log(\"Username: \" + name) // access to name so we can add it to database\r\n    setUsername(currUser => {\r\n      return [{name: name, auth: false}]\r\n    })\r\n\r\n    if (password === '') return //handle error\r\n    console.log(\"Password: \" + password) // access to password so we can add it to database\r\n    setUsername(currUser => {\r\n      return [{password: password, auth: false}]\r\n    })\r\n\r\n    // reset values\r\n    userNameRef.current.value = null\r\n    passwordRef.current.value = null\r\n  }\r\n\r\n  return (\r\n    <>\r\n      <sign className='sign-up'>\r\n        <div className='container'>\r\n          <Users users={users} />\r\n          <li className='sign-item-a'>\r\n            First Name*\r\n          </li>\r\n          <li className='sign-item-b'>\r\n            <input ref={firstNameRef} type=\"text\" />\r\n          </li>\r\n          <li className='sign-item-a'>\r\n            Last Name*\r\n          </li>\r\n          <li className='sign-item-b'>\r\n            <input ref={lastNameRef} type=\"text\" />\r\n          </li>\r\n          <li className='sign-item-a'>\r\n            Email*\r\n          </li>\r\n          <li className='sign-item-b'>\r\n            <input ref={userNameRef} type=\"text\" />\r\n          </li>\r\n          <li className='sign-item-a'>\r\n            Password*\r\n          </li>\r\n          <li className='sign-item-b'>\r\n            <input ref={passwordRef} type=\"text\" />\r\n          </li>\r\n          <li className='sign-item'>\r\n            <button\r\n            className={`btn btn--outline-su btn--medium`}\r\n            onClick={handleFormSubmit}\r\n            >Sign Up</button>\r\n          </li>\r\n        </div>\r\n      </sign>\r\n    </>\r\n  );\r\n  \r\n}","C:\\Users\\jnam0\\Documents\\GitHub\\agSocialNetwork\\front-react\\src\\components\\Pages\\Settings.js",[],"C:\\Users\\jnam0\\Documents\\GitHub\\agSocialNetwork\\front-react\\src\\components\\Pages\\Profile.js",[],"C:\\Users\\jnam0\\Documents\\GitHub\\agSocialNetwork\\front-react\\src\\components\\Pages\\Users.js",[],"C:\\Users\\jnam0\\Documents\\GitHub\\agSocialNetwork\\front-react\\src\\components\\Button\\Button.js",[],"C:\\Users\\jnam0\\Documents\\GitHub\\agSocialNetwork\\front-react\\src\\components\\Pages\\Login.js",["58","59","60"],"C:\\Users\\jnam0\\Documents\\GitHub\\agSocialNetwork\\front-react\\src\\components\\Pages\\LoginUser.js",[],"C:\\Users\\jnam0\\Documents\\GitHub\\agSocialNetwork\\front-react\\src\\components\\Pages\\Dashboard.js",[],{"ruleId":"61","replacedBy":"62"},{"ruleId":"63","replacedBy":"64"},{"ruleId":"65","severity":1,"message":"66","line":1,"column":17,"nodeType":"67","messageId":"68","endLine":1,"endColumn":25},{"ruleId":"65","severity":1,"message":"69","line":3,"column":26,"nodeType":"67","messageId":"68","endLine":3,"endColumn":32},{"ruleId":"65","severity":1,"message":"70","line":3,"colu